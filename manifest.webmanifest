<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>DFW Concierge — Bookings</title>
<style>
  :root {
    --navy: #0B3D6B;
    --teal: #00C8E8;
    --gold: #FFD700;
    --bg: #F4F7FA;
    --card: #FFFFFF;
    --border: #E2EAF0;
    --text: #1a2a3a;
    --muted: #6B8299;
    --green: #16A34A;
    --red: #DC2626;
    --orange: #EA580C;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    padding-bottom: 100px;
  }

  /* Header */
  .header {
    background: var(--navy);
    padding: 20px 16px 16px;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 12px rgba(0,0,0,0.2);
  }

  .header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
  }

  .header-brand {
    font-size: 16px;
    font-weight: 800;
    color: white;
    letter-spacing: .02em;
  }

  .header-brand span { color: var(--teal); }

  .header-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }

  .stat-box {
    background: rgba(255,255,255,0.1);
    border-radius: 8px;
    padding: 10px 8px;
    text-align: center;
  }

  .stat-value {
    font-size: 20px;
    font-weight: 900;
    color: white;
    line-height: 1;
  }

  .stat-value.gold { color: var(--gold); }

  .stat-label {
    font-size: 10px;
    color: rgba(255,255,255,0.6);
    text-transform: uppercase;
    letter-spacing: .08em;
    margin-top: 3px;
  }

  /* Tab bar */
  .tabs {
    display: flex;
    background: white;
    border-bottom: 2px solid var(--border);
    position: sticky;
    top: 120px;
    z-index: 99;
  }

  .tab {
    flex: 1;
    padding: 12px 6px;
    text-align: center;
    font-size: 13px;
    font-weight: 700;
    color: var(--muted);
    cursor: pointer;
    border-bottom: 3px solid transparent;
    margin-bottom: -2px;
    transition: all .2s;
  }

  .tab.active {
    color: var(--navy);
    border-bottom-color: var(--navy);
  }

  /* Main content */
  .content { padding: 16px; }

  /* Add booking button */
  .add-btn {
    width: 100%;
    background: var(--navy);
    color: white;
    border: none;
    border-radius: 12px;
    padding: 16px;
    font-size: 16px;
    font-weight: 800;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 16px;
    letter-spacing: .02em;
  }

  /* Booking card */
  .booking-card {
    background: var(--card);
    border-radius: 14px;
    border: 1px solid var(--border);
    margin-bottom: 12px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px 10px;
    border-bottom: 1px solid var(--border);
  }

  .card-name {
    font-size: 17px;
    font-weight: 800;
    color: var(--navy);
  }

  .card-price {
    font-size: 20px;
    font-weight: 900;
    color: var(--green);
  }

  .card-body {
    padding: 12px 16px;
    display: grid;
    gap: 8px;
  }

  .card-row {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    color: var(--text);
  }

  .card-icon { font-size: 16px; min-width: 20px; }
  .card-label { color: var(--muted); font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; }
  .card-val { font-weight: 600; }

  .card-footer {
    padding: 10px 16px;
    background: #F8FAFC;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .status-badge {
    font-size: 11px;
    font-weight: 800;
    padding: 4px 10px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: .06em;
  }

  .status-confirmed { background: #DCFCE7; color: var(--green); }
  .status-pending { background: #FEF9C3; color: #854D0E; }
  .status-completed { background: #E0E7FF; color: #3730A3; }
  .status-cancelled { background: #FEE2E2; color: var(--red); }

  .card-actions {
    display: flex;
    gap: 8px;
  }

  .action-btn {
    background: none;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 6px 12px;
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    color: var(--navy);
  }

  .action-btn.danger { color: var(--red); border-color: #FECACA; }
  .action-btn.complete { color: var(--green); border-color: #BBF7D0; }

  /* Form modal */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 200;
    display: none;
    align-items: flex-end;
  }

  .modal-overlay.open { display: flex; }

  .modal {
    background: white;
    border-radius: 20px 20px 0 0;
    padding: 24px 20px 40px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
  }

  .modal-title {
    font-size: 20px;
    font-weight: 900;
    color: var(--navy);
    margin-bottom: 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .close-btn {
    background: var(--bg);
    border: none;
    border-radius: 50%;
    width: 32px;
    height: 32px;
    font-size: 18px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .form-group {
    margin-bottom: 16px;
  }

  .form-label {
    font-size: 12px;
    font-weight: 700;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: .08em;
    margin-bottom: 6px;
    display: block;
  }

  .form-input {
    width: 100%;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    padding: 12px 14px;
    font-size: 16px;
    color: var(--text);
    background: white;
    outline: none;
    font-family: inherit;
  }

  .form-input:focus { border-color: var(--navy); }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .submit-btn {
    width: 100%;
    background: var(--navy);
    color: white;
    border: none;
    border-radius: 12px;
    padding: 16px;
    font-size: 16px;
    font-weight: 800;
    cursor: pointer;
    margin-top: 8px;
  }

  /* Empty state */
  .empty {
    text-align: center;
    padding: 60px 20px;
    color: var(--muted);
  }

  .empty-icon { font-size: 48px; margin-bottom: 12px; }
  .empty-title { font-size: 18px; font-weight: 700; color: var(--navy); margin-bottom: 6px; }
  .empty-sub { font-size: 14px; }

  /* Month header */
  .month-header {
    font-size: 13px;
    font-weight: 800;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: .1em;
    margin: 16px 0 8px;
  }

  /* Revenue summary */
  .revenue-card {
    background: var(--navy);
    border-radius: 14px;
    padding: 20px;
    margin-bottom: 16px;
    color: white;
  }

  .revenue-title {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: rgba(255,255,255,0.6);
    margin-bottom: 16px;
  }

  .revenue-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .revenue-item { }
  .revenue-amount {
    font-size: 28px;
    font-weight: 900;
    color: var(--gold);
    line-height: 1;
  }

  .revenue-label {
    font-size: 12px;
    color: rgba(255,255,255,0.6);
    margin-top: 4px;
  }
</style>

<!-- iPhone / PWA install settings -->
<link rel="manifest" href="manifest.webmanifest">
<meta name="theme-color" content="#0B3D6B">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="DFW Concierge">
<link rel="apple-touch-icon" href="icons/icon-180.png">
</head>
<body>

<!-- Header -->
<div class="header">
  <div class="header-top">
    <div class="header-brand">DFW <span>Concierge</span> Bookings</div>
    <div style="font-size:22px">✈️</div>
  </div>
  <div class="header-stats">
    <div class="stat-box">
      <div class="stat-value" id="stat-total">0</div>
      <div class="stat-label">Total Rides</div>
    </div>
    <div class="stat-box">
      <div class="stat-value gold" id="stat-revenue">$0</div>
      <div class="stat-label">Revenue</div>
    </div>
    <div class="stat-box">
      <div class="stat-value" id="stat-upcoming">0</div>
      <div class="stat-label">Upcoming</div>
    </div>
  </div>
</div>

<!-- Tabs -->
<div class="tabs">
  <div class="tab active" onclick="switchTab('upcoming')">📅 Upcoming</div>
  <div class="tab" onclick="switchTab('completed')">✅ Completed</div>
  <div class="tab" onclick="switchTab('all')">📋 All</div>
</div>

<!-- Content -->
<div class="content">
  <button class="add-btn" onclick="openModal()">➕ Add New Booking</button>
  <div id="bookings-list"></div>
</div>

<!-- Add Booking Modal -->
<div class="modal-overlay" id="modal">
  <div class="modal">
    <div class="modal-title">
      New Booking
      <button class="close-btn" onclick="closeModal()">✕</button>
    </div>

    <div class="form-group">
      <label class="form-label">Customer Name</label>
      <input class="form-input" id="f-name" placeholder="e.g. Sal Palatiere" type="text"/>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Date</label>
        <input class="form-input" id="f-date" type="date"/>
      </div>
      <div class="form-group">
        <label class="form-label">Pickup Time</label>
        <input class="form-input" id="f-time" type="time"/>
      </div>
    </div>

    <div class="form-group">
      <label class="form-label">Pickup Address</label>
      <input class="form-input" id="f-pickup" placeholder="e.g. 5324 Gatesworth Lane, Dallas" type="text"/>
    </div>

    <div class="form-group">
      <label class="form-label">Drop Off</label>
      <input class="form-input" id="f-dropoff" placeholder="e.g. DFW Terminal E" type="text"/>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Price ($)</label>
        <input class="form-input" id="f-price" placeholder="e.g. 60" type="number"/>
      </div>
      <div class="form-group">
        <label class="form-label">Passengers</label>
        <input class="form-input" id="f-passengers" placeholder="e.g. 2" type="number"/>
      </div>
    </div>

    <div class="form-group">
      <label class="form-label">Phone Number</label>
      <input class="form-input" id="f-phone" placeholder="e.g. (214) 532-2666" type="tel"/>
    </div>

    <div class="form-group">
      <label class="form-label">Notes</label>
      <input class="form-input" id="f-notes" placeholder="e.g. Gated community, 2 bags" type="text"/>
    </div>

    <div class="form-group">
      <label class="form-label">Payment Status</label>
      <select class="form-input" id="f-payment">
        <option value="pending">Pending</option>
        <option value="paid">Paid</option>
      </select>
    </div>

    <button class="submit-btn" onclick="saveBooking()">✅ Save Booking</button>
  </div>
</div>

<script>
  let bookings = JSON.parse(localStorage.getItem('dfw_bookings') || '[]');
  let currentTab = 'upcoming';
  let editingId = null;

  // Pre-load existing customers
  if (bookings.length === 0) {
    bookings = [
      { id: 1, name: 'Sal Palatiere', date: '2026-08-16', time: '17:00', pickup: 'Richardson, TX', dropoff: 'AT&T Stadium', price: 80, passengers: 1, phone: '(832) 515-1057', notes: 'Round trip — concert', payment: 'pending', status: 'confirmed' },
      { id: 2, name: 'June Finlay', date: '2026-11-06', time: '03:15', pickup: 'Dothan Lane, Dallas 75229', dropoff: 'DFW Airport', price: 85, passengers: 4, phone: '(214) 642-7144', notes: '2 stops — Dothan Lane + Meadowcrest. Round trip Nov 14 return.', payment: 'pending', status: 'confirmed' },
      { id: 3, name: 'Meryl Harari', date: '2026-07-19', time: '08:30', pickup: '5324 Gatesworth Lane, Dallas 75287', dropoff: 'DFW Airport', price: 60, passengers: 2, phone: '', notes: 'Gated community — let guard know. 2 bags + carry ons. Senior couple.', payment: 'pending', status: 'confirmed' },
    ];
    save();
  }

  function save() {
    localStorage.setItem('dfw_bookings', JSON.stringify(bookings));
    render();
  }

  function render() {
    const now = new Date();
    const today = now.toISOString().split('T')[0];

    let filtered = bookings;
    if (currentTab === 'upcoming') {
      filtered = bookings.filter(b => b.date >= today && b.status !== 'cancelled' && b.status !== 'completed');
      filtered.sort((a,b) => (a.date+a.time).localeCompare(b.date+b.time));
    } else if (currentTab === 'completed') {
      filtered = bookings.filter(b => b.status === 'completed');
      filtered.sort((a,b) => b.date.localeCompare(a.date));
    } else {
      filtered = [...bookings].sort((a,b) => b.date.localeCompare(a.date));
    }

    // Stats
    const upcoming = bookings.filter(b => b.date >= today && b.status !== 'cancelled' && b.status !== 'completed');
    const revenue = bookings.filter(b => b.status === 'completed').reduce((s,b) => s + parseFloat(b.price||0), 0);
    document.getElementById('stat-total').textContent = bookings.filter(b=>b.status!=='cancelled').length;
    document.getElementById('stat-revenue').textContent = '$' + revenue;
    document.getElementById('stat-upcoming').textContent = upcoming.length;

    const list = document.getElementById('bookings-list');

    if (filtered.length === 0) {
      list.innerHTML = `<div class="empty"><div class="empty-icon">${currentTab === 'completed' ? '✅' : '📅'}</div><div class="empty-title">${currentTab === 'upcoming' ? 'No upcoming rides' : 'No bookings here yet'}</div><div class="empty-sub">Tap the button above to add one!</div></div>`;
      return;
    }

    let html = '';
    let lastMonth = '';

    filtered.forEach(b => {
      const dateObj = new Date(b.date + 'T12:00:00');
      const month = dateObj.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
      if (month !== lastMonth) {
        html += `<div class="month-header">${month}</div>`;
        lastMonth = month;
      }

      const dateStr = dateObj.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
      const timeStr = b.time ? new Date('2000-01-01T'+b.time).toLocaleTimeString('en-US', {hour: 'numeric', minute:'2-digit'}) : '';

      const statusClass = {confirmed:'status-confirmed', pending:'status-pending', completed:'status-completed', cancelled:'status-cancelled'}[b.status] || 'status-pending';

      html += `
      <div class="booking-card">
        <div class="card-header">
          <div class="card-name">${b.name}</div>
          <div class="card-price">$${b.price}</div>
        </div>
        <div class="card-body">
          <div class="card-row"><span class="card-icon">📅</span><div><div class="card-label">Date & Time</div><div class="card-val">${dateStr} ${timeStr ? '· ' + timeStr : ''}</div></div></div>
          <div class="card-row"><span class="card-icon">📍</span><div><div class="card-label">Pickup</div><div class="card-val">${b.pickup}</div></div></div>
          <div class="card-row"><span class="card-icon">✈️</span><div><div class="card-label">Drop Off</div><div class="card-val">${b.dropoff}</div></div></div>
          ${b.passengers ? `<div class="card-row"><span class="card-icon">👥</span><div><div class="card-label">Passengers</div><div class="card-val">${b.passengers}</div></div></div>` : ''}
          ${b.phone ? `<div class="card-row"><span class="card-icon">📱</span><div><div class="card-label">Phone</div><div class="card-val"><a href="tel:${b.phone}" style="color:var(--navy)">${b.phone}</a></div></div></div>` : ''}
          ${b.notes ? `<div class="card-row"><span class="card-icon">📝</span><div><div class="card-label">Notes</div><div class="card-val">${b.notes}</div></div></div>` : ''}
          <div class="card-row"><span class="card-icon">💳</span><div><div class="card-label">Payment</div><div class="card-val">${b.payment === 'paid' ? '✅ Paid' : '⏳ Pending'}</div></div></div>
        </div>
        <div class="card-footer">
          <span class="status-badge ${statusClass}">${b.status}</span>
          <div class="card-actions">
            ${b.status !== 'completed' && b.status !== 'cancelled' ? `<button class="action-btn complete" onclick="markComplete(${b.id})">✅ Done</button>` : ''}
            <button class="action-btn" onclick="editBooking(${b.id})">✏️</button>
            <button class="action-btn danger" onclick="deleteBooking(${b.id})">🗑️</button>
          </div>
        </div>
      </div>`;
    });

    list.innerHTML = html;
  }

  function switchTab(tab) {
    currentTab = tab;
    document.querySelectorAll('.tab').forEach((t,i) => t.classList.toggle('active', ['upcoming','completed','all'][i] === tab));
    render();
  }

  function openModal(id = null) {
    editingId = id;
    if (id) {
      const b = bookings.find(b => b.id === id);
      document.getElementById('f-name').value = b.name;
      document.getElementById('f-date').value = b.date;
      document.getElementById('f-time').value = b.time;
      document.getElementById('f-pickup').value = b.pickup;
      document.getElementById('f-dropoff').value = b.dropoff;
      document.getElementById('f-price').value = b.price;
      document.getElementById('f-passengers').value = b.passengers;
      document.getElementById('f-phone').value = b.phone;
      document.getElementById('f-notes').value = b.notes;
      document.getElementById('f-payment').value = b.payment;
    } else {
      ['f-name','f-date','f-time','f-pickup','f-dropoff','f-price','f-passengers','f-phone','f-notes'].forEach(id => document.getElementById(id).value = '');
      document.getElementById('f-payment').value = 'pending';
    }
    document.getElementById('modal').classList.add('open');
  }

  function closeModal() {
    document.getElementById('modal').classList.remove('open');
    editingId = null;
  }

  function saveBooking() {
    const b = {
      id: editingId || Date.now(),
      name: document.getElementById('f-name').value || 'Unknown',
      date: document.getElementById('f-date').value,
      time: document.getElementById('f-time').value,
      pickup: document.getElementById('f-pickup').value,
      dropoff: document.getElementById('f-dropoff').value,
      price: document.getElementById('f-price').value || 0,
      passengers: document.getElementById('f-passengers').value || 1,
      phone: document.getElementById('f-phone').value,
      notes: document.getElementById('f-notes').value,
      payment: document.getElementById('f-payment').value,
      status: 'confirmed'
    };

    if (editingId) {
      const idx = bookings.findIndex(x => x.id === editingId);
      bookings[idx] = {...bookings[idx], ...b};
    } else {
      bookings.push(b);
    }

    save();
    closeModal();
  }

  function markComplete(id) {
    const b = bookings.find(b => b.id === id);
    b.status = 'completed';
    b.payment = 'paid';
    save();
  }

  function editBooking(id) { openModal(id); }

  function deleteBooking(id) {
    if (confirm('Remove this booking?')) {
      bookings = bookings.filter(b => b.id !== id);
      save();
    }
  }

  render();
</script>

<script>
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', () => {
      navigator.serviceWorker.register('./service-worker.js').catch(() => {});
    });
  }
</script>
</body>
</html>